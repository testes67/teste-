-- ========== CATEGORIA CHEST ==========
local chestActive = false
local chestThread = nil
local chestMode = "Teleport"
local chestTweenSpeed = 100

local function ChestFarmLoop()
    while chestActive do
        local chestFolder = workspace:FindFirstChild("ChestModels")
        local targetPart = nil
        if chestFolder then
            for _, model in pairs(chestFolder:GetChildren()) do
                if model:IsA("Model") and (model.Name == "GoldChest" or model.Name == "SilverChest" or model.Name == "DiamondChest") then
                    for _, part in pairs(model:GetDescendants()) do
                        if part:IsA("BasePart") then
                            targetPart = part
                            break
                        end
                    end
                    if targetPart then break end
                end
            end
        end
        if not targetPart then
            task.wait(1)
            continue
        end
        local targetPos = targetPart.CFrame
        if chestMode == "Teleport" then
            Player.Character.HumanoidRootPart.CFrame = targetPos
            task.wait(0.5)
        else
            local hrp = Player.Character.HumanoidRootPart
            local dist = (hrp.Position - targetPos.Position).Magnitude
            local duration = dist / chestTweenSpeed
            if duration < 0.1 then duration = 0.1 end
            local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetPos})
            tween:Play()
            tween.Completed:Wait()
            task.wait(0.5)
        end
        firetouchinterest(Player.Character.HumanoidRootPart, targetPart, 0)
        task.wait(0.2)
        firetouchinterest(Player.Character.HumanoidRootPart, targetPart, 1)
        task.wait(1)
    end
end

