local function getPlayerNames()
    local names = {"None"}
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= Player then
            table.insert(names, plr.Name)
        end
    end
    return names
end

local function updatePlayerHighlights()
    -- remove highlights de jogadores que saíram
    for plr, hl in pairs(playerHighlights) do
        if not plr.Parent or plr ~= Players[plr.Name] then
            hl:Destroy()
            playerHighlights[plr] = nil
        end
    end
    if not espPlayersActive then
        for _, hl in pairs(playerHighlights) do hl:Destroy() end
        playerHighlights = {}
        return
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == Player then continue end
        local char = plr.Character
        if char and char:FindFirstChild("HumanoidRootPart") and not playerHighlights[plr] then
            local team = plr:FindFirstChild("leaderstats") and plr.leaderstats:FindFirstChild("Team")
            local color = Color3.fromRGB(255,255,255)
            if team then
                if team.Value == "Pirates" then color = Color3.fromRGB(255,0,0)
                elseif team.Value == "Marines" then color = Color3.fromRGB(0,0,255)
                end
            end
            local highlight = Instance.new("Highlight")
            highlight.Name = "PlayerESP"
            highlight.FillColor = color
            highlight.FillTransparency = 0.3
            highlight.OutlineColor = color
            highlight.OutlineTransparency = 0
            highlight.Parent = char
            playerHighlights[plr] = highlight
        elseif char and playerHighlights[plr] and not char:FindFirstChild("HumanoidRootPart") then
            playerHighlights[plr]:Destroy()
            playerHighlights[plr] = nil
        end
    end
end

local function startAimbot()
