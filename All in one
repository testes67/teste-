-- ============================================================
-- 1. SISTEMA DE COMBATE (usado em Mastery)
-- ============================================================
local Net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
if not Net then Net = ReplicatedStorage:FindFirstChild("Net") end
local RegisterAttack = Net and Net["RE/RegisterAttack"]
local RegisterHit = Net and Net["RE/RegisterHit"]

if not RegisterAttack or not RegisterHit then
    warn("Módulos de combate não encontrados. Usando fallback VirtualUser.")
end

local function GetSessionID()
    local sendHits = getrenv()._G.SendHitsToServer
    if sendHits then
        local combatThread = getupvalues(sendHits)[1]
        if combatThread then
            local userSlice = tostring(Player.UserId):sub(2, 4)
            local memSlice = tostring(combatThread):sub(11, 15)
            return userSlice .. memSlice
        end
    end
    return "00000000"
end

local function Attack(targetCharacter)
    if RegisterAttack and RegisterHit then
        pcall(function()
            RegisterAttack:FireServer(0.5)
            task.wait()
            local leg = targetCharacter:FindFirstChild("RightLowerLeg") or targetCharacter:FindFirstChild("HumanoidRootPart")
            if leg then
                local data = { leg, {}, nil, GetSessionID() }
                RegisterHit:FireServer(unpack(data))
            end
        end)
    else
        VirtualUser:CaptureController()
        VirtualUser:Button1Down(Vector2.new(1280, 672))
        task.wait(0.02)
        VirtualUser:Button1Up(Vector2.new(1280, 672))
    end
end

-- ============================================================
-- 2. CATEGORIA MASTERY (Auto Farm Nearest)
-- ============================================================
local masteryActive = false
local masteryThread = nil
local masteryRange = 50
local masterySpeed = 150
local masteryHeight = 15

local function MoveToNPC_Mastery(npcRoot)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local targetPos = npcRoot.Position + Vector3.new(0, masteryHeight, 0)
    local dist = (hrp.Position - targetPos).Magnitude
    local duration = dist / masterySpeed
    if duration < 0.1 then duration = 0.1 end
    local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
    tween:Play()
    tween.Completed:Wait()
end

local function MasteryLoop()
    while masteryActive do
        local nearest = nil
        local bestDist = masteryRange
        for _, v in pairs(workspace.Enemies:GetChildren()) do
            local hrp = v:FindFirstChild("HumanoidRootPart")
            local hum = v:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (Player.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if dist < bestDist then
                    nearest = v
                    bestDist = dist
                end
            end
        end
        if not nearest then
            task.wait(0.5)
            continue
        end
        local npcRoot = nearest.HumanoidRootPart
        MoveToNPC_Mastery(npcRoot)
        while masteryActive and nearest and nearest.Parent and nearest.Humanoid and nearest.Humanoid.Health > 0 do
            local hrp = Player.Character.HumanoidRootPart
            local targetPos = npcRoot.Position + Vector3.new(0, masteryHeight, 0)
            if (hrp.Position - targetPos).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetPos)
            end
            Attack(nearest)
            task.wait(0.2)
        end
        task.wait(0.3)
    end
end

-- ============================================================
-- 3. CATEGORIA FRUIT (ESP Fruits + Go to Fruit + Walk on Water)
-- ============================================================
local espActive = false
local espLabels = {}
local goActive = false
local currentTween = nil
local goThread = nil
local flySpeed = 100
local walkActive = false
local platformParts = {}
local waterPos = Vector3.new(-16561.259765625, -4, 835.57958984375)
local partSize = 2048
local espessura = 20
local gridSize = 31

local function createPlatform()
    if #platformParts > 0 then return end
    local half = (gridSize - 1) / 2
    local step = partSize
    for i = 0, gridSize-1 do
        for j = 0, gridSize-1 do
            local part = Instance.new("Part")
            part.Name = "WaterWalkPlatform"
            part.Size = Vector3.new(partSize, espessura, partSize)
            local offsetX = (i - half) * step
            local offsetZ = (j - half) * step
            part.Position = Vector3.new(
                waterPos.X + offsetX,
                waterPos.Y - (espessura / 2),
                waterPos.Z + offsetZ
            )
            part.Anchored = true
            part.CanCollide = true
            part.Transparency = 0.5
            part.Color = Color3.fromRGB(0, 200, 255)
            part.Material = Enum.Material.Plastic
            part.Parent = workspace
            table.insert(platformParts, part)
            task.wait()
        end
    end
end

local function destroyPlatform()
    for _, part in ipairs(platformParts) do part:Destroy() end
    platformParts = {}
end

local function isValidFruit(inst)
    return inst:IsA("Tool") and inst.Name:lower():find("fruit")
end

local function createESP(inst)
    if espLabels[inst] then return end
    local attach = inst:FindFirstChild("Handle") or inst
    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0, 100, 0, 30)
    bill.StudsOffset = Vector3.new(0, 1.5, 0)
    bill.AlwaysOnTop = true
    bill.Parent = attach
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "FRUIT"
    label.TextColor3 = Color3.fromRGB(255, 0, 0)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = bill
    espLabels[inst] = bill
end

local function removeESP(inst)
    if espLabels[inst] then espLabels[inst]:Destroy() end
    espLabels[inst] = nil
end

local function updateESP()
    if not espActive then
        for inst, bill in pairs(espLabels) do bill:Destroy() end
        espLabels = {}
        return
    end
    local current = {}
    local function scan(parent)
        for _, child in pairs(parent:GetChildren()) do
            if isValidFruit(child) then current[child] = true end
            scan(child)
        end
    end
    scan(workspace)
    for inst in pairs(espLabels) do
        if not current[inst] then removeESP(inst) end
    end
    for inst in pairs(current) do
        if not espLabels[inst] then createESP(inst) end
    end
end

local espLoop
local function startESPLoop()
    if espLoop then return end
    espLoop = task.spawn(function()
        while espActive do
            updateESP()
            task.wait(0.5)
        end
        updateESP()
        espLoop = nil
    end)
end

local function enableNoclip()
    local char = Player.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = false end
    end
end

local function disableNoclip()
    local char = Player.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = true end
    end
end

local function getFruitPositions()
    local list = {}
    for inst, _ in pairs(espLabels) do
        local attach = inst:FindFirstChild("Handle") or inst
        if attach and attach:IsA("BasePart") then
            table.insert(list, {pos = attach.Position})
        end
    end
    return list
end

local function tweenTo(pos, speed)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local dist = (hrp.Position - pos).Magnitude
    if dist < 2 then return true end
    local dur = dist / speed
    local tween = TweenService:Create(hrp, TweenInfo.new(dur, Enum.EasingStyle.Linear), {CFrame = CFrame.new(pos)})
    currentTween = tween
    enableNoclip()
    tween:Play()
    tween.Completed:Wait()
    disableNoclip()
    currentTween = nil
    return true
end

local function goLoop()
    while goActive do
        local fruits = getFruitPositions()
        if #fruits == 0 then task.wait(0.5) continue end
        local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(1) continue end
        table.sort(fruits, function(a,b) return (hrp.Position - a.pos).Magnitude < (hrp.Position - b.pos).Magnitude end)
        for _, f in ipairs(fruits) do
            if not goActive then break end
            tweenTo(f.pos, flySpeed)
            if goActive then task.wait(0.3) end
        end
        task.wait(0.2)
    end
    disableNoclip()
end

local function startGo()
    if goThread then return end
    goThread = task.spawn(goLoop)
end

local function stopGo()
    if currentTween then currentTween:Cancel() disableNoclip() currentTween = nil end
    goActive = false
    if goThread then task.cancel(goThread) goThread = nil end
    disableNoclip()
end

