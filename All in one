    addToggle(contentContainer, "Walk on Water: OFF", Color3.fromRGB(76,175,80), function(active)
        walkActive = active
        if active then createPlatform() else destroyPlatform() end
    end)
    local espToggle, _ = addToggle(contentContainer, "ESP Fruits: OFF", Color3.fromRGB(76,175,80), function(active)
        espActive = active
        if active then
            if espLoop then task.cancel(espLoop) end
            espLoop = task.spawn(function()
                while espActive do
                    updateESP()
                    task.wait(0.5)
                end
                updateESP()
            end)
        else
            if espLoop then task.cancel(espLoop); espLoop = nil end
            updateESP()
        end
    end)
    addToggle(contentContainer, "GO TO FRUIT: OFF", Color3.fromRGB(76,175,80), function(active)
        goActive = active
        if active then
            if not espActive then
                espActive = true
                espToggle.Text = "ESP Fruits: ON"
                espToggle.BackgroundColor3 = Color3.fromRGB(244,67,54)
                if espLoop then task.cancel(espLoop) end
                espLoop = task.spawn(function()
                    while espActive do
                        updateESP()
                        task.wait(0.5)
                    end
                    updateESP()
                end)
            end
            startGo()
        else
            stopGo()
        end
    end)
    addSlider(contentContainer, "Velocidade de Voo", 0, 400, flySpeed, function(val)
        flySpeed = val
    end)
    task.wait(0.1)
    contentScrolling.CanvasSize = UDim2.new(0,0,0, contentList.AbsoluteContentSize.Y + 20)
