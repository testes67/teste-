local function showChest()
    clearContent()
    -- 1. Toggle principal
    addToggle(contentContainer, "Auto Farm Chest: OFF", Color3.fromRGB(76,175,80), function(active)
        chestActive = active
        if chestThread then task.cancel(chestThread) end
        if active then chestThread = task.spawn(ChestFarmLoop) end
    end)
    -- 2. Slider (Velocidade Tween)
    addSlider(contentContainer, "Velocidade Tween", 0, 400, chestTweenSpeed, function(val)
        chestTweenSpeed = val
    end)
    -- 3. Dropdown (Modo) - criado por último para ficar sobreposto
    addDropdown(contentContainer, "Modo", {"Teleport", "Tween"}, chestMode, function(selected)
        chestMode = selected
    end)
    task.wait(0.1)
    contentScrolling.CanvasSize = UDim2.new(0,0,0, contentList.AbsoluteContentSize.Y + 20)
end

