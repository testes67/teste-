-- ========== INFINITE TELEPORT (R hotkey) ==========
local infiniteTeleportActive = false
local lastTeleport = 0

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R and infiniteTeleportActive then
        local now = tick()
        if now - lastTeleport < 1 then return end
        local char = Player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local mouse = Player:GetMouse()
        local targetPos = mouse.Hit.Position
        local dist = (char.HumanoidRootPart.Position - targetPos).Magnitude
        if dist <= 10 then
            char.HumanoidRootPart.CFrame = CFrame.new(targetPos)
            lastTeleport = now
        end
    end
end)

